PORT=3001

# Прокси для доступа к api.open-meteo.com из РФ
# Поддерживаются:
#   HTTP/HTTPS  —  OPEN_METEO_PROXY=http://user:pass@proxy.example.com:3128
#   SOCKS5      —  OPEN_METEO_PROXY=socks5://user:pass@proxy.example.com:1080
#   SOCKS4/4a   —  OPEN_METEO_PROXY=socks4://proxy.example.com:1080
# Если переменная не задана — запросы идут напрямую
# OPEN_METEO_PROXY=socks5://user:pass@proxy.example.com:1080
